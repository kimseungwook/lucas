# Lucas production environment reference
# Fill this file locally and map the values into your direct secrets / manifests.
# Do not commit real secrets.

# Cluster / namespace
KUBECTL_CONTEXT=goyo-prd
LUCAS_NAMESPACE=lucas
TARGET_NAMESPACES=all

# LLM backend
LLM_BACKEND=openai-compatible
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=REDACTED

# Slack interactive
SLACK_BOT_TOKEN=REDACTED
SLACK_APP_TOKEN=REDACTED
SRE_ALERT_CHANNEL=

# Slack scheduled alerting
SLACK_WEBHOOK_URL=REDACTED

# Slack emergency actions
SLACK_EMERGENCY_ACTIONS_ENABLED=true
SLACK_ACTION_ALLOWED_CHANNELS=
SLACK_ACTION_ALLOWED_USERS=
SLACK_ACTION_ALLOWED_NAMESPACES=

# Runtime behavior
SRE_MODE=autonomous
SCAN_INTERVAL_SECONDS=3600

# Image distribution
IMAGE_REGISTRY=ghcr.io/a2wio
IMAGE_PULL_SECRET=lucas-regcred

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_HOST=lucas.example.com
DASHBOARD_AUTH_USER=a2wmin
DASHBOARD_AUTH_PASS=REDACTED

# Secret management
SECRET_BACKEND=manual
